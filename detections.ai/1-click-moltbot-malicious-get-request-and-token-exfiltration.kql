// Name: 1-Click Moltbot Malicious GET Request and Token Exfiltration
// Author: Reyben T. Cortes
// Date: 2026-02-01
// Description: Detects a malicious GET request attempting to exploit the Moltbot dashboard to exfiltrate authentication tokens via a manipulated WebSocket URL. This rule has two parts: one detects the initial GET request with a suspicious 'gatewayUrl' parameter, and the second detects the subsequent token exfiltration over a WebSocket connection.
// Tactics: Initial Access, Credential Access
// Severity: High

// Define the regex for a JWT-like authentication token pattern.
let TokenRegex = @'^[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+$';

// Part 1: Detect the malicious GET request that triggers the exploit.
let MaliciousGet = AzureDiagnostics
    | where TimeGenerated > ago(30m)
    // This detection targets web server logs. Adjust the Category for your specific log source (e.g., AppServiceHTTPLogs, Nginx, App Insights 'requests').
    | where Category in ("AppServiceHTTPLogs", "FunctionAppLogs", "Request")
    | where Method == "GET"
    // Look for requests to common Moltbot UI paths containing the 'gatewayUrl' parameter.
    | where (Url contains "/chat" or Url contains "/dashboard" or Url contains "/control") and Url has "gatewayUrl=" and Url has "ws"
    | extend ParsedUrl = parse_url(Url)
    | extend GatewayParam = tostring(ParsedUrl.QueryParameters.gatewayUrl)
    | where isnotempty(GatewayParam) and GatewayParam matches regex @"^wss?://"
    // FP Tuning: Exclude legitimate WebSocket gateway domains and localhost to reduce false positives.
    // You MUST replace 'your-expected-gateway-domain' with your actual domain.
    | where GatewayParam !contains "wss://your-expected-gateway-domain/" and GatewayParam !contains "localhost" and GatewayParam !contains "127.0.0.1"
    | project
        TimeGenerated,
        DetectionType = "MaliciousGET_Trigger",
        Url,
        SourceIp = ClientIP,
        GatewayParam,
        UserAgent = tostring(HTTPRequest.UserAgent);

// Part 2: Detect the exfiltration of the token over a WebSocket connection.
let TokenExfil = DeviceNetworkEvents
    | where Timestamp > ago(30m)
    // This part requires network events with payload inspection, often from Microsoft Defender for Endpoint.
    | where ActionType in ("ConnectionSuccess", "ConnectionAttempt") and Protocol == "WebSocket"
    // Focus on unexpected or non-standard WebSocket connections.
    | where RemoteUrl !contains "wss://your-expected-gateway-domain/" and RemoteUrl startswith "ws://"
    // The exploit PoC uses port 13337 and a '/gw' path. This can be adjusted if other variants are observed.
    | where RemotePort == 13337 or RemoteUrl has "/gw"
    // This assumes the network payload is captured in the 'AdditionalFields.Payload' column. Adjust if your schema is different.
    | extend Payload = tostring(AdditionalFields.Payload)
    | where isnotempty(Payload) and Payload has "auth" and Payload has "token"
    // Extract the token value from the expected JSON structure.
    | extend ExtractedToken = extract(@'"token":\s*"([^"]+)"', 1, Payload)
    | where isnotempty(ExtractedToken)
    // Filter for tokens that match JWT characteristics (length and pattern).
    | where strlen(ExtractedToken) between (150 .. 500)
    | where ExtractedToken matches regex TokenRegex
    | project
        TimeGenerated = Timestamp,
        DetectionType = "TokenExfil_Detected",
        RemoteUrl,
        RemoteIp,
        DeviceName,
        InitiatingProcessName,
        ExtractedToken;

// Union the results from both detection parts.
MaliciousGet
| union TokenExfil
| extend
    timestamp = TimeGenerated,
    AccountCustomEntity = SourceIp,
    HostCustomEntity = DeviceName,
    IPCustomEntity = RemoteIp,
    URLCustomEntity = Url
